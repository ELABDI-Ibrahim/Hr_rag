# ─── LLM (Groq) ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Multilingual model — works well for French & English compliance docs
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── Retrieval Tuning ─────────────────────────────────────────────────────────
# How many files BM25 shortlists (Stage 1)
BM25_TOP_K=5
# How many pages semantic search retrieves per exigence (Stage 2)
SEMANTIC_TOP_M=3
# Pages with fewer characters than this are treated as scanned → OCR fallback
MIN_TEXT_LENGTH=50

# ─── OCR ─────────────────────────────────────────────────────────────────────
# Tesseract language codes (install tesseract-ocr-fra and tesseract-ocr-eng)
OCR_LANGUAGES=fra+eng

# ─── File Paths ───────────────────────────────────────────────────────────────
PROOF_FOLDER=./proof
EXCEL_INPUT=./exigences.xlsx
EXCEL_OUTPUT=./results.xlsx
